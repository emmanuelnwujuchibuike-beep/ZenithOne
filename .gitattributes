# Auto-detect text files and normalize line endings to LF
* text=auto

# Source files — always LF
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.ts   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sql  text eol=lf
*.env  text eol=lf

# Binary files — never touch
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.svg  text eol=lf
