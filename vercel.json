{
  "outputDirectory": "src",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        { "key": "Permissions-Policy", "value": "publickey-credentials-create=(*), publickey-credentials-get=(*)" }
      ]
    }
  ]
}
